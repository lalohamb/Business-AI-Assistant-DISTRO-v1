# Business Assistant Box Configuration
AI_PROVIDER=ollama
LOCAL_LLM_ENABLED=true
OPENCLAW_API_KEY=
OPENCLAW_MODEL=
# OPENCLAW_WORKSPACE_PATH=/home/laloahambrickday/Downloads/.nativeblackbox/opt/business-assistant-box/openclaw  # FIXED 2026-06-03: incorrect path used Downloads instead of Documents
OPENCLAW_WORKSPACE_PATH=/home/ubuntu/.business-assistant-box/business-assistant-box/openclaw
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# PostgreSQL credentials
PG_HOST=localhost
PG_PORT=5432
PG_USER=admin
PG_PASSWORD=strongpassword
PG_DATABASE=businessassistant

EMBEDDING_PROVIDER=ollama
# Embedding model options (change EMBEDDING_DIMENSIONS to match):
#   nomic-embed-text     → 768 dimensions  (default, fast, 137M params)
#   mxbai-embed-large    → 1024 dimensions (better accuracy, 335M params)
#   snowflake-arctic-embed → 1024 dimensions (enterprise/retrieval focused, 335M params)
EMBEDDING_MODEL=nomic-embed-text
ACTIVE_CLIENT=insurance-agency
# BASE_PATH=/home/laloahambrickday/Downloads/.nativeblackbox/opt/business-assistant-box  # FIXED 2026-06-03: incorrect path used Downloads instead of Documents — broke all scripts referencing BASE_PATH
BASE_PATH=/home/ubuntu/.business-assistant-box/business-assistant-box
OBSIDIAN_ENABLED=true
# OBSIDIAN_VAULT_PATH=/home/laloahambrickday/Downloads/.nativeblackbox/opt/business-assistant-box/current-client  # FIXED 2026-06-03: same Downloads vs Documents mismatch
OBSIDIAN_VAULT_PATH=/home/ubuntu/.business-assistant-box/business-assistant-box/current-client
# Must match the model above: nomic-embed-text=768, mxbai-embed-large=1024, snowflake-arctic-embed=1024
EMBEDDING_DIMENSIONS=768
RAG_ENABLED=true
DASHBOARD_ENABLED=true
WORKFLOW_ENGINE=n8n
N8N_BASE_URL=http://localhost:5678
