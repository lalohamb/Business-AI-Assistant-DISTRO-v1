# ==========================================
# SAFETY CONTROLS (not read from .env)
# ==========================================
# DRY_RUN and SAFE_MODE are set INSIDE each script or via environment override.
# They are NOT loaded from this file.
#
# DRY_RUN=true
#   Simulates the entire script without making any changes.
#   Prints what WOULD happen (files created, containers started, etc.)
#   Nothing is written, installed, or modified. Safe to run anytime.
#   Think of it as a rehearsal — see the full plan with zero consequences.
#
# SAFE_MODE=true
#   Prevents overwriting existing files without creating a backup first.
#   Prompts before replacing any file.
#   Never removes containers or volumes automatically.
#
# To enable:
#   DRY_RUN=true ./admin/install.sh
#   SAFE_MODE=false ./admin/configure_n8n.sh
#
# Defaults:
#   DRY_RUN=false   (scripts execute changes for real)
#   SAFE_MODE=true  (scripts backup before overwrite, never destroy)
#
# Scripts that use these:
#   - install.sh
#   - configure_n8n.sh
#   - customize_ui_n8n.sh
#   - post_install_client_setup.sh
#
#
